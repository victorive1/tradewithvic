DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
TWELVEDATA_API_KEY=your-api-key-here

# Admin console gate (same token unlocks /dashboard/brain admin + /dashboard/admin/billing)
ADMIN_REFRESH_SECRET=pick-a-long-random-string

# --- Stripe (cards) ---
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...            # sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# After creating a webhook endpoint at:
#   https://dashboard.stripe.com/webhooks
# pointed at https://tradewithvic.com/api/billing/stripe/webhook
# with events: payment_intent.succeeded, payment_intent.payment_failed, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_...

# --- BitPay (crypto) ---
# Merchant token from BitPay dashboard → Account → API Tokens
BITPAY_TOKEN=your-bitpay-merchant-token
# "prod" for bitpay.com, "test" for test.bitpay.com
BITPAY_ENV=prod
# Optional shared secret you put on the IPN URL to verify authenticity
BITPAY_WEBHOOK_SECRET=pick-a-long-random-string
