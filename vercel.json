{
  "buildCommand": "npx prisma generate && DATABASE_URL=\"$DATABASE_URL_UNPOOLED\" npx prisma migrate deploy && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/brain/scan",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/brain/crypto-refresh",
      "schedule": "1-59/2 * * * *"
    },
    {
      "path": "/api/brain/learn",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/news/ingest",
      "schedule": "*/5 * * * *"
    }
  ]
}
