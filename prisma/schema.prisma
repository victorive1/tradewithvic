generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // user, agent, admin
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  watchlist   Watchlist[]
  alerts      Alert[]
  preferences UserPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== USER PREFERENCES ====================

model UserPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  favoriteMarkets  String   @default("[]")
  defaultTimeframe String   @default("1h")
  dashboardLayout  String   @default("[]")
  alertSettings    String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== MARKET DATA ====================

model Instrument {
  id            String  @id @default(cuid())
  symbol        String  @unique
  displayName   String
  category      String
  baseCurrency  String?
  quoteCurrency String?
  decimalPlaces Int     @default(5)
  isActive      Boolean @default(true)
  scanTier      Int     @default(1)

  setups    TradeSetup[]
  alerts    Alert[]
  snapshots MarketSnapshot[]
  candles   Candle[]
}

// ==================== MARKET BRAIN — SCAN ENGINE ====================

model ScanCycle {
  id                 String    @id @default(cuid())
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  status             String    @default("running")
  durationMs         Int?
  instrumentsScanned Int       @default(0)
  quotesFetched      Int       @default(0)
  candlesFetched     Int       @default(0)
  setupsGenerated    Int       @default(0)
  errorCount         Int       @default(0)
  errorLogJson       String    @default("[]")
  triggeredBy        String    @default("vercel-cron")

  snapshots MarketSnapshot[]

  @@index([startedAt])
  @@index([status])
}

model MarketSnapshot {
  id              String   @id @default(cuid())
  scanCycleId     String
  instrumentId    String?
  symbol          String
  capturedAt      DateTime @default(now())
  price           Float
  change          Float
  changePercent   Float
  high            Float
  low             Float
  open            Float
  previousClose   Float
  sourceTimestamp Int?

  scanCycle  ScanCycle   @relation(fields: [scanCycleId], references: [id], onDelete: Cascade)
  instrument Instrument? @relation(fields: [instrumentId], references: [id])

  @@index([symbol, capturedAt])
  @@index([scanCycleId])
  @@index([capturedAt])
}

model Candle {
  id           String   @id @default(cuid())
  instrumentId String?
  symbol       String
  timeframe    String
  openTime     DateTime
  closeTime    DateTime
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float    @default(0)
  isClosed     Boolean  @default(true)
  fetchedAt    DateTime @default(now())

  instrument Instrument? @relation(fields: [instrumentId], references: [id])

  @@unique([symbol, timeframe, openTime])
  @@index([symbol, timeframe, openTime])
  @@index([fetchedAt])
}

// ==================== MARKET BRAIN — STRUCTURE ENGINE ====================

model StructureState {
  id                 String    @id @default(cuid())
  symbol             String
  timeframe          String
  bias               String // bullish | bearish | range
  lastSwingHigh      Float?
  lastSwingHighTime  DateTime?
  priorSwingHigh     Float?
  priorSwingHighTime DateTime?
  lastSwingLow       Float?
  lastSwingLowTime   DateTime?
  priorSwingLow      Float?
  priorSwingLowTime  DateTime?
  lastSwingsJson     String    @default("[]")
  candlesAnalyzed    Int       @default(0)
  lastEventType      String?
  lastEventAt        DateTime?
  updatedAt          DateTime  @updatedAt

  @@unique([symbol, timeframe])
  @@index([updatedAt])
  @@index([bias])
}

model StructureEvent {
  id               String   @id @default(cuid())
  symbol           String
  timeframe        String
  eventType        String // bos_bullish | bos_bearish | choch_bullish | choch_bearish
  detectedAt       DateTime @default(now())
  priceLevel       Float
  brokerCandleTime DateTime
  brokerClose      Float
  priorBias        String
  newBias          String
  scanCycleId      String?

  @@index([symbol, timeframe, detectedAt])
  @@index([detectedAt])
  @@index([eventType])
}

// ==================== MARKET BRAIN — LIQUIDITY ENGINE ====================

model LiquidityLevel {
  id           String   @id @default(cuid())
  symbol       String
  timeframe    String
  levelType    String // equal_high | equal_low | prev_day_high | prev_day_low | prev_week_high | prev_week_low | session_high | session_low
  price        Float
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  status       String   @default("active") // active | swept | expired
  strength     Int      @default(1) // number of touches for equal H/L, 1 for single levels
  metadataJson String   @default("{}")
  updatedAt    DateTime @updatedAt

  @@unique([symbol, timeframe, levelType, price])
  @@index([symbol, timeframe, status])
  @@index([updatedAt])
}

model LiquidityEvent {
  id               String   @id @default(cuid())
  symbol           String
  timeframe        String
  levelType        String
  levelPrice       Float
  sweepCandleTime  DateTime
  sweepHigh        Float
  sweepLow         Float
  sweepClose       Float
  sweepDirection   String // bullish_sweep | bearish_sweep
  reversalStrength Float // how far the close reversed from the wick, in ATR units or absolute
  detectedAt       DateTime @default(now())
  scanCycleId      String?

  @@unique([symbol, timeframe, levelType, levelPrice, sweepCandleTime])
  @@index([symbol, timeframe, detectedAt])
  @@index([sweepDirection])
  @@index([detectedAt])
}

// ==================== MARKET BRAIN — SUPPLY & DEMAND ZONES ====================
// See docs/supply-demand-blueprint.md for the full spec.

model SupplyDemandZone {
  id        String   @id @default(cuid())
  symbol    String
  timeframe String
  zoneType  String // "supply" | "demand"

  // Boundaries of the zone
  proximal Float
  distal   Float
  midpoint Float

  // Formation / departure metadata
  originTime           DateTime // when the base candle closed
  baseCandles          Int
  departureAtrMultiple Float
  fvgPresent           Boolean  @default(false)
  fvgSize              Float?
  bosFlag              Boolean  @default(false)
  sweepFlag            Boolean  @default(false)

  // Component + final scores (0-100)
  formationScore     Float
  displacementScore  Float
  imbalanceScore     Float
  structureScore     Float
  freshnessScore     Float
  retestQualityScore Float @default(0)
  contextScore       Float @default(0)
  institutionalScore Float
  grade              String // "A+" | "A" | "B" | "WATCH" | "IGNORE"

  // Lifecycle
  freshnessState String  @default("NEW") // NEW | FRESH | ARMED | TOUCHED | PARTIALLY_MITIGATED | CONSUMED | INVALIDATED
  retestCount    Int     @default(0)
  lastRetestAt   DateTime?
  currentPrice   Float?
  penetrationPct Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events SupplyDemandZoneEvent[]

  @@unique([symbol, timeframe, originTime, zoneType])
  @@index([symbol, timeframe, freshnessState])
  @@index([grade, institutionalScore])
  @@index([createdAt])
}

model SupplyDemandZoneEvent {
  id         String   @id @default(cuid())
  zoneId     String
  eventType  String // state_transition | retest | score_recalc
  oldState   String?
  newState   String?
  reason     String?
  price      Float?
  detectedAt DateTime @default(now())

  zone SupplyDemandZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId, detectedAt])
  @@index([eventType])
}

// ==================== MARKET BRAIN — EXECUTION ENGINE (Layer 5) ====================

model ExecutionAccount {
  id                         String    @id @default(cuid())
  name                       String    @unique @default("paper-default")
  mode                       String    @default("paper") // paper | live
  baseCurrency               String    @default("USD")
  startingBalance            Float     @default(10000)
  currentBalance             Float     @default(10000)
  equityHigh                 Float     @default(10000)
  equityLow                  Float     @default(10000)
  totalRealizedPnl           Float     @default(0)
  totalUnrealizedPnl         Float     @default(0)
  totalClosedTrades          Int       @default(0)
  totalWins                  Int       @default(0)
  totalLosses                Int       @default(0)
  dailyPnl                   Float     @default(0)
  dailyPnlResetAt            DateTime?
  riskPerTradePct            Float     @default(1.0)
  maxConcurrentPositions     Int       @default(5)
  maxDailyLossPct            Float     @default(3.0)
  allowedGrades              String    @default("[\"A+\",\"A\"]")
  maxTotalRiskPct            Float     @default(5.0) // max % of balance risked across all open positions
  maxSameDirectionPositions  Int       @default(3) // no more than N positions all long or all short
  maxSameAssetClassPositions Int       @default(3) // e.g., max 3 forex positions concurrently
  maxSameStrategyPositions   Int       @default(2) // max 2 of same setup family (e.g., 2 sweep_reversals)
  maxCurrencyExposurePct     Float     @default(60) // max % of risk sitting on one currency
  weeklyLossLimitPct         Float     @default(8.0)
  weeklyPnl                  Float     @default(0)
  weeklyPnlResetAt           DateTime?
  smartExitMode              String    @default("balanced") // off | conservative | balanced | aggressive
  riskProfile                String    @default("balanced") // off | conservative | balanced | aggressive — Blueprint § 10 preset that drives risk %, max positions, daily loss, and allowed grades
  requireMarketPredictionAlignment Boolean @default(false) // if true, veto setups whose direction doesn't match the Market Prediction engine's bias
  minConfidenceScore         Int       @default(65)
  minRiskReward              Float     @default(1.2)
  selectedSymbolsJson        String    @default("[]") // empty = all CANDLE_SYMBOLS
  allowedTimeframesJson      String    @default("[\"4h\",\"1h\",\"15min\",\"5min\"]") // which TFs may fire trades
  allowedSessionsJson        String    @default("[\"london\",\"newyork\",\"overlap\",\"crypto_24_7\"]")
  newsFilterEnabled          Boolean   @default(true)
  fridayCloseProtection      Boolean   @default(true)
  executionMode              String    @default("paper") // paper | mt_shadow | mt_live
  orderPlacementMode         String    @default("pending_limit") // instant_market | pending_limit | hybrid
  pendingOrderTtlMinutes     Int       @default(240)
  pendingEntryTolerancePct   Float     @default(0.08) // how close price must come to entry to fill (% of entry)
  selectedMtAccountIdsJson   String    @default("[]") // MT account IDs from localStorage (future live routing)
  autoExecuteEnabled         Boolean   @default(true)
  killSwitchEngaged          Boolean   @default(false)
  isActive                   Boolean   @default(true)
  lastCycleAt                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  orders    ExecutionOrder[]
  positions ExecutionPosition[]
  trades    ExecutionTrade[]

  @@index([isActive])
}

model ExecutionOrder {
  id              String    @id @default(cuid())
  accountId       String
  setupId         String    @unique
  decisionLogId   String?
  symbol          String
  timeframe       String
  direction       String
  orderType       String    @default("instant_market") // instant_market | pending_limit
  entry           Float
  stopLoss        Float
  takeProfit1     Float
  takeProfit2     Float?
  takeProfit3     Float?
  riskAmount      Float
  sizeUnits       Float
  grade           String
  confidenceScore Int
  status          String    @default("queued") // pending | queued | filled | cancelled | rejected
  rejectReason    String?
  cancelReason    String?
  validUntil      DateTime?
  filledAt        DateTime?
  filledPrice     Float?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())

  account  ExecutionAccount   @relation(fields: [accountId], references: [id])
  position ExecutionPosition?

  @@index([accountId, status])
  @@index([status, validUntil])
  @@index([createdAt])
}

model ExecutionPosition {
  id                String    @id @default(cuid())
  accountId         String
  orderId           String    @unique
  setupId           String
  decisionLogId     String?
  symbol            String
  timeframe         String
  direction         String
  entry             Float
  stopLoss          Float
  originalStopLoss  Float
  takeProfit1       Float
  takeProfit2       Float?
  takeProfit3       Float?
  sizeUnits         Float
  riskAmount        Float
  grade             String
  status            String    @default("open") // open | closed
  exitPrice         Float?
  exitReason        String?
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  mfe               Float     @default(0)
  mae               Float     @default(0)
  realizedPnl       Float     @default(0)
  unrealizedPnl     Float     @default(0)
  closedPct         Float     @default(0) // 0-100, how much of the position has been closed via partials
  tp1Hit            Boolean   @default(false)
  tp2Hit            Boolean   @default(false)
  tp3Hit            Boolean   @default(false)
  movedToBreakeven  Boolean   @default(false)
  thesisScore       Int       @default(100)
  thesisState       String    @default("strong") // strong | weakening | damaged | invalidated
  lastThesisCheckAt DateTime?
  updatedAt         DateTime  @updatedAt

  account ExecutionAccount @relation(fields: [accountId], references: [id])
  order   ExecutionOrder   @relation(fields: [orderId], references: [id])
  events  ExecutionEvent[]

  @@index([accountId, status])
  @@index([symbol, status])
  @@index([thesisState])
}

model ExecutionTrade {
  id              String   @id @default(cuid())
  accountId       String
  positionId      String   @unique
  setupId         String
  symbol          String
  timeframe       String
  direction       String
  grade           String
  entry           Float
  exit            Float
  stopLoss        Float
  sizeUnits       Float
  riskAmount      Float
  realizedPnl     Float
  pnlPct          Float
  rMultiple       Float
  exitReason      String
  openedAt        DateTime
  closedAt        DateTime
  durationMinutes Int
  mfe             Float
  mae             Float
  maxThesisScore  Int      @default(100)
  minThesisScore  Int      @default(100)

  account ExecutionAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, closedAt])
  @@index([symbol, closedAt])
  @@index([exitReason])
}

model ExecutionEvent {
  id           String   @id @default(cuid())
  positionId   String
  eventType    String // opened | sl_hit | tp1_hit | tp2_hit | tp3_hit | partial_closed | sl_moved_breakeven | sl_moved_trail | thesis_change | closed_manual | closed_thesis
  price        Float?
  fromValue    String?
  toValue      String?
  reason       String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  position ExecutionPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@index([eventType])
}

model ExecutionGuardrailLog {
  id             String   @id @default(cuid())
  setupId        String
  accountId      String
  passed         Boolean
  failureReasons String   @default("[]")
  checkedAt      DateTime @default(now())

  @@index([setupId])
  @@index([checkedAt])
  @@index([passed])
}

// ==================== MARKET BRAIN — PORTFOLIO RISK (Layer 6) ====================

model PortfolioSnapshot {
  id                    String   @id @default(cuid())
  accountId             String
  capturedAt            DateTime @default(now())
  balance               Float
  equity                Float
  openPositionsCount    Int
  totalRiskAmount       Float
  totalRiskPct          Float
  unrealizedPnl         Float
  dailyPnl              Float
  weeklyPnl             Float
  longCount             Int      @default(0)
  shortCount            Int      @default(0)
  categoryBreakdownJson String   @default("{}") // { forex: 2, crypto: 1, metals: 0, ... }
  strategyBreakdownJson String   @default("{}") // { sweep_reversal: 2, breakout: 1, ... }
  currencyExposureJson  String   @default("{}") // { USD: 50, EUR: 20, ... } — % of total risk
  drawdownPct           Float    @default(0)

  @@index([accountId, capturedAt])
}

model PortfolioDecisionLog {
  id           String   @id @default(cuid())
  accountId    String
  setupId      String
  decision     String // allow | reduce | reject
  reasons      String   @default("[]")
  originalRisk Float
  adjustedRisk Float?
  createdAt    DateTime @default(now())

  @@index([setupId])
  @@index([createdAt])
  @@index([decision])
}

// ==================== MARKET BRAIN — FUNDAMENTAL ENGINE ====================

model FundamentalEvent {
  id                     String   @id @default(cuid())
  eventTime              DateTime
  country                String
  eventName              String
  impact                 String // high | medium | low
  forecast               String?
  previous               String?
  actual                 String?
  affectedCurrenciesJson String   @default("[]")
  affectedSymbolsJson    String   @default("[]")
  source                 String   @default("manual")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([eventTime, country, eventName])
  @@index([eventTime])
  @@index([impact])
}

model EventRiskSnapshot {
  id                 String   @id @default(cuid())
  symbol             String
  riskLevel          String // none | low | medium | high
  nearestEventId     String?
  nearestEventName   String?
  nearestEventImpact String?
  minutesToEvent     Int?
  computedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([symbol])
  @@index([riskLevel])
  @@index([computedAt])
}

// Unscheduled / breaking market news that can move markets outside the
// economic calendar — central bank surprises, geopolitical headlines,
// commodity shocks. Severity drives the top-of-screen alert bar.
model MarketNewsHeadline {
  id                  String    @id @default(cuid())
  publishedAt         DateTime
  headline            String
  summary             String?
  severity            String // red | orange | green
  category            String    @default("general") // macro | geopolitical | central_bank | commodity | general
  affectedSymbolsJson String    @default("[]")
  sourceName          String
  sourceUrl           String?
  externalId          String? // upstream id for dedup
  isActive            Boolean   @default(true) // set false once we've decided the market has absorbed it
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([sourceName, externalId])
  @@index([publishedAt])
  @@index([severity, isActive])
  @@index([isActive, publishedAt])
}

// ==================== BILLING & PAYMENTS ====================

model BillingAccount {
  id               String   @id @default(cuid())
  userKey          String   @unique
  currency         String   @default("USD")
  availableBalance Float    @default(0)
  pendingBalance   Float    @default(0)
  lockedBalance    Float    @default(0)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentMethods PaymentMethod[]
  deposits       DepositRequest[]
  withdrawals    WithdrawalRequest[]
  transactions   BillingTransaction[]

  @@index([createdAt])
}

model PaymentMethod {
  id                String    @id @default(cuid())
  billingAccountId  String
  methodType        String // card | bank | wallet
  processorName     String // stripe | paddle | coinbase | manual
  processorTokenRef String // NEVER store raw PAN — only processor token
  brand             String?
  last4             String?
  expiryMonth       Int?
  expiryYear        Int?
  nickname          String?
  isDefault         Boolean   @default(false)
  isActive          Boolean   @default(true)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId, isActive])
}

model CryptoDestination {
  id                  String   @id @default(cuid())
  ownerScope          String // user | business
  ownerKey            String? // userKey for user scope, null for business
  currencyCode        String // BTC | ETH | USDC | USDT | ...
  destinationType     String // wallet_address | processor_account
  walletAddressRef    String?
  processorAccountRef String?
  network             String? // bitcoin | ethereum | polygon | solana | ...
  nickname            String?
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@index([ownerScope, ownerKey, currencyCode])
}

model DepositRequest {
  id                 String    @id @default(cuid())
  billingAccountId   String
  userKey            String
  amount             Float
  currency           String    @default("USD")
  methodType         String // card | crypto
  methodId           String?
  processorChargeRef String?
  networkHash        String?
  status             String    @default("initiated") // initiated | pending | completed | failed | reversed | under_review | cancelled
  statusReason       String?
  feeAmount          Float     @default(0)
  netAmount          Float?
  expiresAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId, status])
  @@index([userKey])
  @@index([createdAt])
}

model WithdrawalRequest {
  id               String    @id @default(cuid())
  billingAccountId String
  userKey          String
  amount           Float
  currency         String    @default("USD")
  destinationType  String // bank | crypto
  destinationRef   String
  destinationLabel String?
  feeAmount        Float     @default(0)
  netAmount        Float?
  status           String    @default("initiated") // initiated | pending | completed | failed | reversed | under_review | cancelled
  statusReason     String?
  reviewNotes      String?
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId, status])
  @@index([status, createdAt])
}

model BillingTransaction {
  id               String   @id @default(cuid())
  billingAccountId String
  userKey          String
  transactionType  String // deposit | withdrawal | fee | refund | adjustment
  referenceType    String? // deposit_request | withdrawal_request | manual
  referenceId      String?
  amount           Float
  currency         String   @default("USD")
  status           String   @default("completed")
  description      String?
  metadataJson     String   @default("{}")
  createdAt        DateTime @default(now())

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId, createdAt])
  @@index([transactionType])
}

model BillingWebhookEvent {
  id               String    @id @default(cuid())
  providerName     String
  eventType        String
  eventRef         String
  payloadJson      String
  processingStatus String    @default("pending") // pending | processed | failed | ignored
  processingError  String?
  receivedAt       DateTime  @default(now())
  processedAt      DateTime?

  @@unique([providerName, eventRef])
  @@index([providerName, processingStatus])
  @@index([receivedAt])
}

model BillingAdminSetting {
  id               String   @id @default(cuid())
  paymentMethodKey String   @unique
  isEnabled        Boolean  @default(true)
  minAmount        Float    @default(10)
  maxAmount        Float    @default(100000)
  feeRuleJson      String   @default("{}")
  reviewRuleJson   String   @default("{}")
  updatedAt        DateTime @updatedAt
}

// ==================== COMMUNITY (Phase 1) ====================

model CommunityProfile {
  id                  String   @id @default(cuid())
  userKey             String   @unique
  username            String   @unique
  displayName         String
  bio                 String?
  avatarEmoji         String   @default("👤")
  favoriteMarketsJson String   @default("[]")
  tradingStyle        String?
  followerCount       Int      @default(0)
  followingCount      Int      @default(0)
  postCount           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  posts     CommunityPost[]     @relation("authored")
  comments  CommunityComment[]
  reactions CommunityReaction[]
  followers CommunityFollow[]   @relation("followTarget")
  following CommunityFollow[]   @relation("followOrigin")

  @@index([createdAt])
}

model CommunityFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  CommunityProfile @relation("followOrigin", fields: [followerId], references: [id], onDelete: Cascade)
  following CommunityProfile @relation("followTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model CommunityPost {
  id                 String   @id @default(cuid())
  authorId           String
