// ============================================================================
// Direct Trade Execution (MT4/MT5) — spec §6
// Lets users place trades directly from the platform to their linked MT
// accounts. Kept separate from ExecutionAccount (which is the Brain's
// auto-executor); this scope is for user-initiated manual tickets.
// ============================================================================

model LinkedTradingAccount {
  id                String    @id @default(cuid())
  userKey           String // same localStorage user identity pattern as billing
  platformType      String // "MT4" | "MT5"
  brokerName        String
  serverName        String
  accountLogin      String // broker login id
  accountLabel      String?
  baseCurrency      String    @default("USD")
  leverage          Int?
  connectionStatus  String    @default("linked") // linked | disconnected | error | pending_verification
  lastConnectedAt   DateTime?
  adapterKind       String    @default("pending_queue") // pending_queue | metaapi | ea_webhook | mock
  adapterConfigJson String? // JSON — adapter-specific config (API key ref, webhook URL, etc.)

  // Per-account broker symbol overrides — applied at order routing time.
  // brokerSymbolSuffix is appended to every symbol (e.g. ".ecn" on JustMarkets ECN).
  // brokerSymbolRenames is a JSON map of internal → broker name where the symbol
  //   is renamed beyond a suffix (e.g. {"USOIL":"WTI","NAS100":"US100"}). The
  //   rename value is bare; the suffix is appended after the rename.
  brokerSymbolSuffix  String  @default("")
  brokerSymbolRenames String  @default("{}")

  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  requests TradeExecutionRequest[]

  @@index([userKey, isActive])
  @@index([connectionStatus])
}

model TradeExecutionRequest {
  id              String    @id @default(cuid())
  userKey         String
  accountId       String
  internalSymbol  String // FX Wonders canonical symbol (e.g. "EURUSD")
  brokerSymbol    String? // mapped broker symbol (e.g. "EURUSD.m")
  side            String // "buy" | "sell"
  orderType       String // "market" | "limit" | "stop" | "stop_limit"
  requestedVolume Float // lots
  sizingMode      String    @default("fixed_lots") // fixed_lots | risk_percent
  riskPercent     Float? // present when sizingMode = risk_percent
  entryPrice      Float? // required for non-market orders
  stopLoss        Float?
  takeProfit      Float?
  timeInForce     String    @default("gtc") // gtc | day | ioc | fok
  expiresAt       DateTime?
  slippagePips    Int?
  comment         String?
  magicNumber     Int?
  sourceType      String? // signal | setup | editors_pick | brain | manual
  sourceRef       String? // id of originating signal/setup
  status          String    @default("pending_submission") // pending_submission | validating | submitted | filled | rejected | cancelled | expired | failed
  statusReason    String?
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account LinkedTradingAccount     @relation(fields: [accountId], references: [id])
  result  TradeExecutionResult?
  audit   TradeExecutionAuditLog[]

  @@index([userKey, status])
  @@index([accountId, status])
  @@index([createdAt])
}

model TradeExecutionResult {
  id              String   @id @default(cuid())
  requestId       String   @unique
  executionStatus String // accepted | rejected | partial | pending | error
  brokerTicketRef String?
  fillPrice       Float?
  filledVolume    Float?
  remainingVolume Float?
  slippagePips    Float?
  commissionCost  Float?
  swap            Float?
  rejectionReason String?
  adapterResponse String? // raw response JSON from adapter (truncated)
  returnedAt      DateTime @default(now())

  request TradeExecutionRequest @relation(fields: [requestId], references: [id])

  @@index([executionStatus])
  @@index([returnedAt])
}

model TradeExecutionAuditLog {
  id          String   @id @default(cuid())
  requestId   String
  eventType   String // created | validated | submitted | ack | fill | reject | cancel | error
  actor       String   @default("user") // user | system | adapter
  payloadJson String?
  createdAt   DateTime @default(now())

  request TradeExecutionRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([eventType, createdAt])
}

model SymbolMappingRule {
  id             String   @id @default(cuid())
  internalSymbol String // canonical platform symbol
  brokerSymbol   String // broker-specific symbol (suffix varies)
  brokerName     String? // null = applies to all brokers
  platformType   String // "MT4" | "MT5" | "both"
  contractSize   Float? // standard lot size, e.g. 100000 for FX
  digits         Int?
  minVolume      Float?
  maxVolume      Float?
  volumeStep     Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([internalSymbol, brokerName, platformType])
  @@index([internalSymbol])
  @@index([brokerName])
}

// ============================================================================
// Institutional Flow Intelligence Engine — Phase 1 blueprint
// Multi-layer inference of probable institutional capital entry / defense /
// rotation / exit. Components: Flow Capture, Derivatives, Cross-Asset,
// Venue, Positioning, Catalyst, Regime, Inference Scoring.
// ============================================================================

model FlowEvent {
  id                 String   @id @default(cuid())
  assetSymbol        String
  timeframe          String   @default("5min")
  capturedAt         DateTime @default(now())
  session            String
  side               String
  aggressorRatio     Float    @default(0)
  sweepCount         Int      @default(0)
  spreadBps          Float?
  orderBookImbalance Float?
  vwapDistance       Float?
  absorptionScore    Float    @default(0)
  refillScore        Float    @default(0)
  rawNotional        Float    @default(0)
  sourceKind         String   @default("derived")
  metadataJson       String?

  @@index([assetSymbol, capturedAt])
  @@index([capturedAt])
}

model DerivativesEvent {
  id                String   @id @default(cuid())
  assetSymbol       String
  capturedAt        DateTime @default(now())
  optionSide        String?
  premium           Float?
  relativeSize      Float?
  strike            Float?
  tenorDays         Int?
  ivShift           Float?
  skewShift         Float?
  openInterestDelta Float?
  gammaContext      String?
  sourceKind        String   @default("placeholder")
  metadataJson      String?

  @@index([assetSymbol, capturedAt])
}

model CatalystEvent {
  id                   String   @id @default(cuid())
  assetSymbol          String
  capturedAt           DateTime @default(now())
  catalystType         String
  surpriseScore        Float?
  severity             String   @default("medium")
  sentiment            String   @default("neutral")
  relevanceWindowStart DateTime
  relevanceWindowEnd   DateTime
  headline             String?
  sourceKind           String   @default("derived")
  metadataJson         String?

  @@index([assetSymbol, capturedAt])
  @@index([relevanceWindowEnd])
}

model InstitutionalSignal {
  id              String   @id @default(cuid())
  assetSymbol     String
  capturedAt      DateTime @default(now())
  direction       String
  classification  String
  horizon         String   @default("intraday")
  intentScore     Float
  confidenceGrade String

  flowQuality      Float @default(0)
  derivativesScore Float @default(0)
  crossAssetScore  Float @default(0)
  venueScore       Float @default(0)
  catalystScore    Float @default(0)
  persistenceScore Float @default(0)
  positioningScore Float @default(0)
  regimeScore      Float @default(0)

  defendedLevel     Float?
  invalidationLevel Float?
  persistenceProb   Float?
  explanationJson   String @default("[]")
  evidenceJson      String @default("{}")

  active             Boolean   @default(true)
  invalidatedAt      DateTime?
  invalidationReason String?

  @@index([assetSymbol, active, capturedAt])
  @@index([intentScore])
  @@index([capturedAt])
}
