// ==================== ADMIN ALGO RUNTIME ====================
//
// Admin-only algo bots. Each bot has one AlgoBotConfig row (keyed by
// botId string, e.g. "breakout", "md", "us30", etc.) that the dashboard
// UI reads/writes and that the server-side runtime loop consults every
// 2 minutes to route matching TradeSetups through the real MT adapter.

model AlgoBotConfig {
  id                     String   @id @default(cuid())
  botId                  String   @unique // "breakout" | "md" | "us30" | "metals" | "ob" | "fx-strength" | "vic" | "hub"
  enabled                Boolean  @default(false)
  running                Boolean  @default(false)

  // Strategy filter — which setupTypes from the Brain to consider.
  // Stored as comma-separated list so Postgres is happy either way.
  strategyFilter         String   @default("") // e.g. "breakout" or "breakout,trend_pullback"
  symbolFilter           String   @default("") // empty = all, otherwise "EURUSD,GBPUSD,..."

  // Sizing
  sizingMode             String   @default("fixed_lot") // fixed_lot | risk_percent
  fixedLotSize           Float    @default(0.10)
  riskPercent            Float    @default(1.0)

  // Auto Lot Sizing — opt-in extra layer.
  // closeAt1R: override the setup's TP and exit at +1R from entry.
  // autoLotSizingEnabled: size each trade so SL = -$amount and 1R = +$amount;
  //   implies closeAt1R because the dollar target equals the 1R level.
  closeAt1R              Boolean  @default(false)
  autoLotSizingEnabled   Boolean  @default(false)
  autoLotSizingAmount    Float    @default(0)

  // Quality + risk gates
  minScore               Int      @default(75)
  minRiskReward          Float    @default(1.5)
  maxOpenPositions       Int      @default(3)
  maxPerPair             Int      @default(1)
  maxSamePairInRow       Int      @default(2)
  dailyDrawdownPercent   Float    @default(3.0)
  pauseAfterLosses       Int      @default(3)

  // Accounts (LinkedTradingAccount.accountLogin list)
  selectedAccounts       String   @default("") // csv of logins

  // Filters
  newsFilter             Boolean  @default(true)
  fridayCloseProtection  Boolean  @default(true)
  preCloseBufferMinutes  Int      @default(30)
  allowedSessions        String   @default("london,newyork")

  ownerUserKey           String?  // admin that owns the bot — usually a single admin in practice

  lastRunAt              DateTime?
  lastErrorAt            DateTime?
  lastErrorMessage       String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  executions             AlgoBotExecution[]

  @@index([enabled])
  @@index([updatedAt])
}

// One row per setup the runtime has routed (or attempted to route) for
// a given bot — used for dedup, audit, and showing "Trades Today" on
// the dashboard.
model AlgoBotExecution {
  id              String   @id @default(cuid())
  algoBotConfigId String
  botId           String
  setupId         String
  symbol          String
  direction       String
  grade           String?
  accountLogin    String
  accountId       String?

  status          String   // "routed" | "rejected" | "duplicate" | "filtered"
  rejectReason    String?

  tradeRequestId  String?  // TradeExecutionRequest.id
  tradeResultId   String?  // TradeExecutionResult.id
  brokerOrderId   String?

  routedAt        DateTime @default(now())

  algoBotConfig   AlgoBotConfig @relation(fields: [algoBotConfigId], references: [id], onDelete: Cascade)

  @@unique([botId, setupId, accountLogin])
  @@index([botId, routedAt])
  @@index([status])
}

// ==================== MARKET BRAIN — VWAP VOLUME REFERENCE ====================
//
// Real-volume source for the VWAP engine. TwelveData returns 0 volume for
// most spot FX, so for those pairs we fetch a liquid ETF / futures proxy
// (FXE for EURUSD, GLD for XAUUSD, etc.) whose bar volume is genuine
// institutional flow. Crypto / indices that already return real volume
// bypass this table entirely and use Candle.volume directly.
//
// Keyed by (symbol, timeframe, openTime) — same shape as Candle so the
// VWAP engine can LEFT JOIN cleanly. source field records which proxy
// fed the row (futures | etf | spot) so the dashboard can show volume
// lineage.

model VolumeReference {
  id           String   @id @default(cuid())
  symbol       String   // internal FX Wonders symbol e.g. "EURUSD"
  proxySymbol  String   // what we actually hit on TwelveData, e.g. "FXE"
  timeframe    String
  openTime     DateTime
  closeTime    DateTime
  volume       Float
  source       String   @default("etf") // etf | futures | spot
  fetchedAt    DateTime @default(now())

  @@unique([symbol, timeframe, openTime])
  @@index([symbol, timeframe])
  @@index([fetchedAt])
}

// ==================== MARKET BRAIN — VWAP ENGINE (Phase 1) ====================
//
// Session / daily / weekly anchored VWAP with σ bands, slope classification,
// and deviation event tracking. Built on the same 2-min scan cadence as the
// other brain layers. FX/metals volume is often 0 on TwelveData so the
// engine falls back to max(1, volume) — the reference level still captures
// mean-reversion behaviour, and we flag "unreliable" in volumeQuality.

model VwapSnapshot {
  id        String @id @default(cuid())
  symbol    String
  timeframe String
  anchor    String // "daily" | "weekly" | "session"

  anchorTime  DateTime
  candleCount Int
  lastClose   Float

  vwap        Float
  upperBand1  Float // +1σ
  lowerBand1  Float // -1σ
  upperBand2  Float // +2σ
  lowerBand2  Float // -2σ
  stddev      Float

  slope      Float // (vwap_now - vwap_n_ago) / n bars
  slopeState String @default("flat") // rising | falling | flat

  deviationPct Float // (price - vwap) / vwap * 100
  zScore       Float // deviation / stddev

  position String // "above" | "below" | "at"
  bias     String // "bullish" | "bearish" | "neutral"
  regime   String @default("balanced") // trend | balanced | stretched | mean_revert | choppy

  volumeQuality String @default("reliable") // reliable | degraded | synthetic

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([symbol, timeframe, anchor])
  @@index([updatedAt])
  @@index([bias])
  @@index([regime])
}

model VwapDeviationEvent {
  id         String   @id @default(cuid())
  symbol     String
  timeframe  String
  anchor     String
  eventType  String // reclaim | rejection | stretch_upper | stretch_lower | snapback
  price      Float
  vwapAtEvent Float
  zScoreAtEvent Float
  reason     String?
  detectedAt DateTime @default(now())

  @@index([symbol, timeframe, anchor])
  @@index([detectedAt])
  @@index([eventType])
}

