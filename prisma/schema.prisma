generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // user, agent, admin
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  watchlist     Watchlist[]
  alerts        Alert[]
  preferences   UserPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== USER PREFERENCES ====================

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  favoriteMarkets String   @default("[]")
  defaultTimeframe String  @default("1h")
  dashboardLayout String   @default("[]")
  alertSettings   String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== MARKET DATA ====================

model Instrument {
  id          String @id @default(cuid())
  symbol      String @unique
  displayName String
  category    String
  baseCurrency  String?
  quoteCurrency String?
  decimalPlaces Int    @default(5)
  isActive    Boolean @default(true)
  scanTier    Int     @default(1)

  setups      TradeSetup[]
  alerts      Alert[]
  snapshots   MarketSnapshot[]
  candles     Candle[]
}

// ==================== MARKET BRAIN — SCAN ENGINE ====================

model ScanCycle {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @default("running")
  durationMs      Int?
  instrumentsScanned Int    @default(0)
  quotesFetched   Int       @default(0)
  candlesFetched  Int       @default(0)
  setupsGenerated Int       @default(0)
  errorCount      Int       @default(0)
  errorLogJson    String    @default("[]")
  triggeredBy     String    @default("vercel-cron")

  snapshots       MarketSnapshot[]

  @@index([startedAt])
  @@index([status])
}

model MarketSnapshot {
  id             String   @id @default(cuid())
  scanCycleId    String
  instrumentId   String?
  symbol         String
  capturedAt     DateTime @default(now())
  price          Float
  change         Float
  changePercent  Float
  high           Float
  low            Float
  open           Float
  previousClose  Float
  sourceTimestamp Int?

  scanCycle   ScanCycle   @relation(fields: [scanCycleId], references: [id], onDelete: Cascade)
  instrument  Instrument? @relation(fields: [instrumentId], references: [id])

  @@index([symbol, capturedAt])
  @@index([scanCycleId])
  @@index([capturedAt])
}

model Candle {
  id            String   @id @default(cuid())
  instrumentId  String?
  symbol        String
  timeframe     String
  openTime      DateTime
  closeTime     DateTime
  open          Float
  high          Float
  low           Float
  close         Float
  volume        Float    @default(0)
  isClosed      Boolean  @default(true)
  fetchedAt     DateTime @default(now())

  instrument Instrument? @relation(fields: [instrumentId], references: [id])

  @@unique([symbol, timeframe, openTime])
  @@index([symbol, timeframe, openTime])
  @@index([fetchedAt])
}

// ==================== MARKET BRAIN — STRUCTURE ENGINE ====================

model StructureState {
  id                String   @id @default(cuid())
  symbol            String
  timeframe         String
  bias              String   // bullish | bearish | range
  lastSwingHigh     Float?
  lastSwingHighTime DateTime?
  priorSwingHigh    Float?
  priorSwingHighTime DateTime?
  lastSwingLow      Float?
  lastSwingLowTime  DateTime?
  priorSwingLow     Float?
  priorSwingLowTime DateTime?
  lastSwingsJson    String   @default("[]")
  candlesAnalyzed   Int      @default(0)
  lastEventType     String?
  lastEventAt       DateTime?
  updatedAt         DateTime @updatedAt

  @@unique([symbol, timeframe])
  @@index([updatedAt])
  @@index([bias])
}

model StructureEvent {
  id              String   @id @default(cuid())
  symbol          String
  timeframe       String
  eventType       String   // bos_bullish | bos_bearish | choch_bullish | choch_bearish
  detectedAt      DateTime @default(now())
  priceLevel      Float
  brokerCandleTime DateTime
  brokerClose     Float
  priorBias       String
  newBias         String
  scanCycleId     String?

  @@index([symbol, timeframe, detectedAt])
  @@index([detectedAt])
  @@index([eventType])
}

// ==================== MARKET BRAIN — LIQUIDITY ENGINE ====================

model LiquidityLevel {
  id          String   @id @default(cuid())
  symbol      String
  timeframe   String
  levelType   String   // equal_high | equal_low | prev_day_high | prev_day_low | prev_week_high | prev_week_low | session_high | session_low
  price       Float
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  status      String   @default("active") // active | swept | expired
  strength    Int      @default(1)        // number of touches for equal H/L, 1 for single levels
  metadataJson String   @default("{}")
  updatedAt   DateTime @updatedAt

  @@unique([symbol, timeframe, levelType, price])
  @@index([symbol, timeframe, status])
  @@index([updatedAt])
}

model LiquidityEvent {
  id              String   @id @default(cuid())
  symbol          String
  timeframe       String
  levelType       String
  levelPrice      Float
  sweepCandleTime DateTime
  sweepHigh       Float
  sweepLow        Float
  sweepClose      Float
  sweepDirection  String   // bullish_sweep | bearish_sweep
  reversalStrength Float   // how far the close reversed from the wick, in ATR units or absolute
  detectedAt      DateTime @default(now())
  scanCycleId     String?

  @@unique([symbol, timeframe, levelType, levelPrice, sweepCandleTime])
  @@index([symbol, timeframe, detectedAt])
  @@index([sweepDirection])
  @@index([detectedAt])
}

// ==================== MARKET BRAIN — EXECUTION ENGINE (Layer 5) ====================

model ExecutionAccount {
  id                     String   @id @default(cuid())
  name                   String   @unique @default("paper-default")
  mode                   String   @default("paper") // paper | live
  baseCurrency           String   @default("USD")
  startingBalance        Float    @default(10000)
  currentBalance         Float    @default(10000)
  equityHigh             Float    @default(10000)
  equityLow              Float    @default(10000)
  totalRealizedPnl       Float    @default(0)
  totalUnrealizedPnl     Float    @default(0)
  totalClosedTrades      Int      @default(0)
  totalWins              Int      @default(0)
  totalLosses            Int      @default(0)
  dailyPnl               Float    @default(0)
  dailyPnlResetAt        DateTime?
  riskPerTradePct        Float    @default(1.0)
  maxConcurrentPositions Int      @default(5)
  maxDailyLossPct        Float    @default(3.0)
  allowedGrades          String   @default("[\"A+\",\"A\"]")
  smartExitMode          String   @default("balanced") // off | conservative | balanced | aggressive
  autoExecuteEnabled     Boolean  @default(true)
  killSwitchEngaged      Boolean  @default(false)
  isActive               Boolean  @default(true)
  lastCycleAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  orders    ExecutionOrder[]
  positions ExecutionPosition[]
  trades    ExecutionTrade[]

  @@index([isActive])
}

model ExecutionOrder {
  id              String   @id @default(cuid())
  accountId       String
  setupId         String   @unique
  decisionLogId   String?
  symbol          String
  timeframe       String
  direction       String
  entry           Float
  stopLoss        Float
  takeProfit1     Float
  takeProfit2     Float?
  takeProfit3     Float?
  riskAmount      Float
  sizeUnits       Float
  grade           String
  confidenceScore Int
  status          String   @default("queued") // queued | filled | cancelled | rejected
  rejectReason    String?
  filledAt        DateTime?
  filledPrice     Float?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())

  account  ExecutionAccount   @relation(fields: [accountId], references: [id])
  position ExecutionPosition?

  @@index([accountId, status])
  @@index([createdAt])
}

model ExecutionPosition {
  id                String    @id @default(cuid())
  accountId         String
  orderId           String    @unique
  setupId           String
  decisionLogId     String?
  symbol            String
  timeframe         String
  direction         String
  entry             Float
  stopLoss          Float
  originalStopLoss  Float
  takeProfit1       Float
  takeProfit2       Float?
  takeProfit3       Float?
  sizeUnits         Float
  riskAmount        Float
  grade             String
  status            String    @default("open") // open | closed
  exitPrice         Float?
  exitReason        String?
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  mfe               Float     @default(0)
  mae               Float     @default(0)
  realizedPnl       Float     @default(0)
  unrealizedPnl     Float     @default(0)
  closedPct         Float     @default(0) // 0-100, how much of the position has been closed via partials
  tp1Hit            Boolean   @default(false)
  tp2Hit            Boolean   @default(false)
  tp3Hit            Boolean   @default(false)
  movedToBreakeven  Boolean   @default(false)
  thesisScore       Int       @default(100)
  thesisState       String    @default("strong") // strong | weakening | damaged | invalidated
  lastThesisCheckAt DateTime?
  updatedAt         DateTime  @updatedAt

  account ExecutionAccount @relation(fields: [accountId], references: [id])
  order   ExecutionOrder   @relation(fields: [orderId], references: [id])
  events  ExecutionEvent[]

  @@index([accountId, status])
  @@index([symbol, status])
  @@index([thesisState])
}

model ExecutionTrade {
  id              String   @id @default(cuid())
  accountId       String
  positionId      String   @unique
  setupId         String
  symbol          String
  timeframe       String
  direction       String
  grade           String
  entry           Float
  exit            Float
  stopLoss        Float
  sizeUnits       Float
  riskAmount      Float
  realizedPnl     Float
  pnlPct          Float
  rMultiple       Float
  exitReason      String
  openedAt        DateTime
  closedAt        DateTime
  durationMinutes Int
  mfe             Float
  mae             Float
  maxThesisScore  Int      @default(100)
  minThesisScore  Int      @default(100)

  account ExecutionAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, closedAt])
  @@index([symbol, closedAt])
  @@index([exitReason])
}

model ExecutionEvent {
  id          String   @id @default(cuid())
  positionId  String
  eventType   String   // opened | sl_hit | tp1_hit | tp2_hit | tp3_hit | partial_closed | sl_moved_breakeven | sl_moved_trail | thesis_change | closed_manual | closed_thesis
  price       Float?
  fromValue   String?
  toValue     String?
  reason      String?
  metadataJson String  @default("{}")
  createdAt   DateTime @default(now())

  position ExecutionPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@index([eventType])
}

model ExecutionGuardrailLog {
  id             String   @id @default(cuid())
  setupId        String
  accountId      String
  passed         Boolean
  failureReasons String   @default("[]")
  checkedAt      DateTime @default(now())

  @@index([setupId])
  @@index([checkedAt])
  @@index([passed])
}

// ==================== MARKET BRAIN — FUNDAMENTAL ENGINE ====================

model FundamentalEvent {
  id              String   @id @default(cuid())
  eventTime       DateTime
  country         String
  eventName       String
  impact          String   // high | medium | low
  forecast        String?
  previous        String?
  actual          String?
  affectedCurrenciesJson String @default("[]")
  affectedSymbolsJson    String @default("[]")
  source          String   @default("manual")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([eventTime, country, eventName])
  @@index([eventTime])
  @@index([impact])
}

model EventRiskSnapshot {
  id              String   @id @default(cuid())
  symbol          String
  riskLevel       String   // none | low | medium | high
  nearestEventId  String?
  nearestEventName String?
  nearestEventImpact String?
  minutesToEvent  Int?
  computedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([symbol])
  @@index([riskLevel])
  @@index([computedAt])
}

// ==================== MARKET BRAIN — SENTIMENT ENGINE ====================

model SentimentSnapshot {
  id          String   @id @default(cuid())
  scanCycleId String?
  computedAt  DateTime @default(now())
  riskTone    String   // risk_on | risk_off | neutral
  riskScore   Int      // -100 (risk-off) to +100 (risk-on)
  usdBias     String   // strong | weak | neutral
  usdScore    Float
  goldBias    String   // bid | offered | neutral
  goldChange  Float
  cryptoBias  String   // bid | offered | neutral
  cryptoChange Float
  reasoningJson String  @default("[]")
  reasoning   String

  @@index([computedAt])
  @@index([riskTone])
}

// ==================== MARKET BRAIN — INDICATOR ENGINE ====================

model IndicatorSnapshot {
  id          String   @id @default(cuid())
  symbol      String
  timeframe   String
  candleTime  DateTime
  close       Float
  candleCount Int

  ema20       Float?
  ema50       Float?
  ema200      Float?

  rsi14       Float?
  rsiState    String?  // overbought | oversold | neutral

  atr14       Float?
  atrPercent  Float?   // atr as % of close

  macdLine    Float?
  macdSignal  Float?
  macdHist    Float?

  bbUpper     Float?
  bbMiddle    Float?
  bbLower     Float?
  bbWidth     Float?
  bbPercentB  Float?

  trendBias   String   @default("neutral") // bullish | bearish | neutral
  momentum    String   @default("neutral") // up | down | flat

  computedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([symbol, timeframe])
  @@index([updatedAt])
  @@index([trendBias])
}

// ==================== TRADE SETUPS ====================

model TradeSetup {
  id              String   @id @default(cuid())
  instrumentId    String
  symbol          String
  direction       String
  setupType       String
  timeframe       String
  entry           Float
  stopLoss        Float
  takeProfit1     Float
  takeProfit2     Float?
  takeProfit3     Float?
  riskReward      Float
  confidenceScore Int
  qualityGrade    String
  explanation     String?
  invalidation    String?
  status          String   @default("active")
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([symbol, status])
  @@index([createdAt])
  @@index([qualityGrade])
}

// ==================== WATCHLIST ====================

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

// ==================== ALERTS ====================

model Alert {
  id           String   @id @default(cuid())
  userId       String
  instrumentId String?
  symbol       String
  alertType    String
  condition    String
  message      String?
  isTriggered  Boolean  @default(false)
  triggeredAt  DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument Instrument? @relation(fields: [instrumentId], references: [id])

  @@index([userId, isActive])
  @@index([symbol, isActive])
}

// ==================== ADAPTIVE INTELLIGENCE - DECISION LOGGING ====================

model SetupDecisionLog {
  id                     String   @id @default(cuid())
  setupId                String?
  createdAt              DateTime @default(now())
  symbol                 String
  timeframe              String
  session                String
  marketRegime           String?
  rulesEngineVersion     String   @default("v1")
  modelVersionUsed       String?
  adaptiveConfigVersion  String?
  direction              String
  setupType              String
  rulesScore             Float
  hybridScore            Float?
  qualityLabel           String
  entry                  Float
  stopLoss               Float
  takeProfit1            Float
  takeProfit2            Float?
  takeProfit3            Float?
  pairStrengthSpread     Float?
  alignmentScore         Float?
  structureScore         Float?
  momentumScore          Float?
  entryLocationScore     Float?
  rrScore                Float?
  volatilityScore        Float?
  eventRiskScore         Float?
  featureVectorJson      String   @default("{}")
  reasoningJson          String   @default("[]")
  invalidationRulesJson  String   @default("[]")
  marketContextJson      String   @default("{}")
  rawInputSnapshotJson   String   @default("{}")

  outcomes               SetupOutcome[]
  interactions           SetupUserInteraction[]
  liveScoringLogs        LiveScoringLog[]
  shadowPredictionLogs   ShadowPredictionLog[]

  @@index([createdAt])
  @@index([symbol, timeframe])
  @@index([rulesEngineVersion])
}

// ==================== ADAPTIVE INTELLIGENCE - OUTCOMES ====================

model SetupOutcome {
  id                     String   @id @default(cuid())
  setupDecisionLogId     String   @unique
  labeledAt              DateTime @default(now())
  triggered              Boolean
  entryTriggeredAt       DateTime?
  tp1Hit                 Boolean  @default(false)
  tp1HitAt               DateTime?
  tp2Hit                 Boolean  @default(false)
  tp2HitAt               DateTime?
  tp3Hit                 Boolean  @default(false)
  tp3HitAt               DateTime?
  slHit                  Boolean  @default(false)
  slHitAt                DateTime?
  expired                Boolean  @default(false)
  invalidated            Boolean  @default(false)
  neverTriggered         Boolean  @default(false)
  maxFavorableExcursion  Float?
  maxAdverseExcursion    Float?
  barsToTrigger          Int?
  barsToTp1              Int?
  barsToSl               Int?
  outcomeClass           String   // excellent, good, neutral, poor, invalid
  outcomeScore           Float?
  labelingWindowMinutes  Int      @default(360)
  labelQuality           String   @default("medium") // high, medium, low

  setupDecisionLog SetupDecisionLog @relation(fields: [setupDecisionLogId], references: [id], onDelete: Cascade)

  @@index([labeledAt])
  @@index([outcomeClass])
}

model SetupUserInteraction {
  id                  String   @id @default(cuid())
  setupDecisionLogId  String
  userId              String?
  eventType           String   // viewed, expanded, clicked_chart, saved, ignored
  eventValue          String?
  metadataJson        String?
  createdAt           DateTime @default(now())

  setupDecisionLog SetupDecisionLog @relation(fields: [setupDecisionLogId], references: [id], onDelete: Cascade)

  @@index([setupDecisionLogId])
  @@index([createdAt])
}

// ==================== ADAPTIVE INTELLIGENCE - MODEL REGISTRY ====================

model TrainingDataset {
  id                   String   @id @default(cuid())
  datasetName          String
  createdAt            DateTime @default(now())
  windowStart          DateTime
  windowEnd            DateTime
  labelType            String
  rowCount             Int
  featureListJson      String   @default("[]")
  targetDefinitionJson String   @default("{}")
  artifactPath         String?
  status               String   // ready, training, completed, failed

  models ModelRegistry[]

  @@index([createdAt])
}

model ModelRegistry {
  id                     String   @id @default(cuid())
  modelName              String
  modelFamily            String
  version                String   @unique
  status                 String   // candidate, shadow, active, rejected, archived, rolled_back
  createdAt              DateTime @default(now())
  trainedAt              DateTime
  trainingWindowStart    DateTime
  trainingWindowEnd      DateTime
  datasetId              String?
  targetName             String
  featureListJson        String   @default("[]")
  hyperparamsJson        String   @default("{}")
  metricsJson            String   @default("{}")
  calibrationMetricsJson String?
  artifactPath           String
  evaluationReportPath   String?
  notes                  String?
  promotedAt             DateTime?
  demotedAt              DateTime?
  replacedByVersion      String?

  dataset          TrainingDataset? @relation(fields: [datasetId], references: [id])
  promotionsFrom   ModelPromotion[] @relation("PromotionFrom")
  promotionsTo     ModelPromotion[] @relation("PromotionTo")
  driftReports     FeatureDriftReport[]

  @@index([status])
  @@index([modelName])
}

model ModelPromotion {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  fromVersion         String?
  toVersion           String
  actionType          String   // promote_to_shadow, promote_to_active, rollback, reject
  decisionReason      String
  approvedBy          String
  metricsSnapshotJson String   @default("{}")
  rolloutStrategyJson String?

  fromModel ModelRegistry? @relation("PromotionFrom", fields: [fromVersion], references: [version])
  toModel   ModelRegistry  @relation("PromotionTo", fields: [toVersion], references: [version])

  @@index([createdAt])
}

// ==================== ADAPTIVE INTELLIGENCE - CONFIG ====================

model AdaptiveConfigVersion {
  id                     String   @id @default(cuid())
  version                String   @unique
  status                 String   // candidate, active, archived, rolled_back
  createdAt              DateTime @default(now())
  activatedAt            DateTime?
  deactivatedAt          DateTime?
  parentVersion          String?
  changeReason           String?
  maxDailyChangePercent  Float    @default(5)
  weightsJson            String   @default("{}")
  thresholdsJson         String   @default("{}")
  symbolModifiersJson    String   @default("{}")
  timeframeModifiersJson String   @default("{}")
  sessionModifiersJson   String   @default("{}")
  freshnessRulesJson     String   @default("{}")
  stalenessRulesJson     String   @default("{}")
  eventRiskRulesJson     String   @default("{}")
  notes                  String?

  @@index([status])
  @@index([createdAt])
}

// ==================== ADAPTIVE INTELLIGENCE - SCORING AUDIT ====================

model LiveScoringLog {
  id                       String   @id @default(cuid())
  setupDecisionLogId       String
  createdAt                DateTime @default(now())
  scoringMode              String   // rules_only, shadow, hybrid
  rulesScore               Float
  modelScore               Float?
  calibratedProbability    Float?
  visibleScore             Float
  rulesWeight              Float
  modelWeight              Float
  activeModelVersion       String?
  shadowModelVersion       String?
  adaptiveConfigVersion    String?
  fallbackUsed             Boolean  @default(false)
  fallbackReason           String?
  guardrailApplied         Boolean  @default(false)
  guardrailReasonsJson     String?

  setupDecisionLog SetupDecisionLog @relation(fields: [setupDecisionLogId], references: [id], onDelete: Cascade)

  @@index([setupDecisionLogId])
  @@index([createdAt])
  @@index([scoringMode])
}

model ShadowPredictionLog {
  id                    String   @id @default(cuid())
  setupDecisionLogId    String
  createdAt             DateTime @default(now())
  activeScore           Float
  activeModelVersion    String?
  shadowModelVersion    String
  shadowProbability     Float
  shadowScore           Float
  divergence            Float
  featureHash           String?
  notesJson             String?

  setupDecisionLog SetupDecisionLog @relation(fields: [setupDecisionLogId], references: [id], onDelete: Cascade)

  @@index([setupDecisionLogId])
  @@index([createdAt])
}

// ==================== ADAPTIVE INTELLIGENCE - MONITORING ====================

model FeatureDriftReport {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  modelVersion         String?
  windowStart          DateTime
  windowEnd            DateTime
  driftSummaryJson     String   @default("{}")
  severity             String   // stable, warning, critical
  recommendedAction    String?

  model ModelRegistry? @relation(fields: [modelVersion], references: [version])

  @@index([createdAt])
  @@index([severity])
}

model MonitoringAlert {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  resolvedAt         DateTime?
  level              String   // info, warning, critical
  category           String   // operational, calibration, drift, outcome
  title              String
  message            String
  modelVersion       String?
  configVersion      String?
  metricName         String?
  metricValue        Float?
  thresholdValue     Float?
  status             String   @default("open") // open, acknowledged, resolved
  recommendedAction  String?
  actionTaken        String?

  @@index([createdAt])
  @@index([level])
  @@index([status])
}

model MonitoringSnapshot {
  id                         String   @id @default(cuid())
  createdAt                  DateTime @default(now())
  activeModelVersion         String?
  adaptiveConfigVersion      String?
  scoringMode                String
  inferenceSuccessRate       Float?
  fallbackRate               Float?
  topBucketHitRate           Float?
  topBucketFalsePositiveRate Float?
  driftSeverity              String?
  driftSummaryJson           String?
  scoreBandSummaryJson       String?

  @@index([createdAt])
}

model DailyLearningReport {
  id                      String   @id @default(cuid())
  reportDate              DateTime @unique
  createdAt               DateTime @default(now())
  setupsLogged            Int
  setupsLabeled           Int
  candidateModelVersion   String?
  baselineMetricsJson     String   @default("{}")
  candidateMetricsJson    String?
  recommendationsJson     String?
  promotionDecision       String?

  @@index([createdAt])
}

// ==================== OPERATOR CONTROL ====================

model OperatorActionLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  operatorId   String
  actionType   String
  targetType   String
  targetId     String?
  reason       String?
  metadataJson String?

  @@index([createdAt])
  @@index([operatorId])
}

model SystemControlState {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  scoringMode            String   @default("rules_only")
  rulesWeight            Float    @default(1.0)
  modelWeight            Float    @default(0.0)
  forceRulesOnly         Boolean  @default(false)
  configPromotionsFrozen Boolean  @default(false)
  activeModelVersion     String?
  shadowModelVersion     String?
  activeConfigVersion    String?
  notes                  String?
}
